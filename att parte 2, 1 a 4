#include <stdio.h>
#include <stdlib.h>

typedef struct No {
    int valor;
    struct No *prox;
} No;

void inserirPosicao(No **head, int valor, int posicao) {
    if (posicao < 0) {
        printf("Erro: posicao invalida.\n");
        return;
    }

    No *novo = malloc(sizeof(No));
    if (novo == NULL) {
        printf("Erro ao alocar memoria.\n");
        return;
    }

    novo->valor = valor;
    novo->prox = NULL;

    if (posicao == 0) {
        novo->prox = *head;
        *head = novo;
        return;
    }

    No *atual = *head;
    int i = 0;

    while (atual != NULL && i < posicao - 1) {
        atual = atual->prox;
        i++;
    }

    if (atual == NULL) {
        printf("Erro: posição inválida.\n");
        free(novo);
        return;
    }

    novo->prox = atual->prox;
    atual->prox = novo;
}

int buscarValor(No *head, int valor) {
    int posicao = 0;

    while (head != NULL) {
        if (head->valor == valor) {
            return posicao;
        }

        head = head->prox;
        posicao++;
    }

    return -1;
}

void inverterLista(No **head) {
    No *anterior = NULL;
    No *atual = *head;
    No *proximo = NULL;

    while (atual != NULL) {
        proximo = atual->prox;
        atual->prox = anterior;
        anterior = atual;
        atual = proximo;
    }

    *head = anterior;
}

void dividirLista(No *head, No **lista1, No **lista2) {
    if (head == NULL) {
        *lista1 = NULL;
        *lista2 = NULL;
        return;
    }

    No *lento = head;
    No *rapido = head;
    No *anterior = NULL;

    while (rapido != NULL && rapido->prox != NULL) {
        rapido = rapido->prox->prox;
        anterior = lento;
        lento = lento->prox;
    }

    if (rapido != NULL) {
        anterior = lento;
        lento = lento->prox;
    }

    *lista1 = head;
    *lista2 = lento;

    if (anterior != NULL) {
        anterior->prox = NULL;
    }
}

void exibirLista(No *head) {
    if (head == NULL) {
        printf("Lista vazia.\n");
        return;
    }

    while (head != NULL) {
        printf("%d -> ", head->valor);
        head = head->prox;
    }

    printf("NULL\n");
}

void liberarLista(No *head) {
    No *temp;

    while (head != NULL) {
        temp = head;
        head = head->prox;
        free(temp);
    }
}

int main() {
    No *lista = NULL;
    No *lista1 = NULL;
    No *lista2 = NULL;

    int opcao;
    int valor;
    int posicao;
    int resultado;

    do {
        printf("\n===== GERENCIADOR DE LISTA =====\n");
        printf("1 - Inserir valor em posição especifica\n");
        printf("2 - Buscar valor\n");
        printf("3 - Inverter lista\n");
        printf("4 - Dividir lista em duas\n");
        printf("5 - Exibir lista\n");
        printf("0 - Sair\n");
        printf("Escolha uma opção: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1:
                printf("Digite o valor: ");
                scanf("%d", &valor);

                printf("Digite a posicao: ");
                scanf("%d", &posicao);

                inserirPosicao(&lista, valor, posicao);
                break;

            case 2:
                printf("Digite o valor para buscar: ");
                scanf("%d", &valor);

                resultado = buscarValor(lista, valor);

                if (resultado == -1) {
                    printf("Valor não encontrado.\n");
                } else {
                    printf("Valor encontrado na posição %d.\n", resultado);
                }
                break;

            case 3:
                inverterLista(&lista);
                printf("Lista agora invertida.\n");
                break;

            case 4:
                dividirLista(lista, &lista1, &lista2);

                printf("Primeira lista:\n");
                exibirLista(lista1);

                printf("Segunda lista:\n");
                exibirLista(lista2);

                lista = NULL;
                break;

            case 5:
                exibirLista(lista);
                break;

            case 0:
                printf("Encerrando...\n");
                break;

            default:
                printf("Opção invalida.\n");
        }

    } while (opcao != 0);

    liberarLista(lista);
    liberarLista(lista1);
    liberarLista(lista2);

    return 0;

}
